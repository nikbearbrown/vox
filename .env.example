# .env.example — copy to .env and fill in the SECRET keys. `.env` is gitignored;
# this example is committed so a fresh clone knows what to set, and it preserves the
# (non-secret) ElevenLabs voice IDs. NEVER put the real API keys in this file.
ELEVENLABS_API_KEY=your-elevenlabs-api-key
FAL_KEY=your-fal-key

# ElevenLabs narration voices (name -> voice_id) — see AUDIENCES.md
ELEVENLABS_VOICE_NIKBEARBROWN=TyW6NH39JcFb5M3xdIIk
ELEVENLABS_VOICE_MEDHAVY=1sgY6Voq1aexKOB1IJ2D
ELEVENLABS_VOICE_HUMANITARIANS=qdEb53HLreRBCD1FQE30
